generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("MONGODB_URI")
}

enum InviteCodeStatus {
  AVAILABLE
  REDEEMED
  EXPIRED
  REVOKED
}

enum AccountSetupStatus {
  PENDING
  READY
  NEEDS_ATTENTION
}

enum AccountSetupEventType {
  WALLET_RESOLUTION_REQUESTED
  WALLET_RESOLUTION_SUCCEEDED
  WALLET_RESOLUTION_PENDING
  WALLET_RESOLUTION_FAILED
}

enum TreasuryDistributionKind {
  INITIAL_ALLOCATION
  INITIAL_GAS_FUNDING
  LOW_BALANCE_GAS_REFILL
  GOVERNANCE_REBALANCE_TOPUP
}

enum TreasuryDistributionStatus {
  PENDING
  PROCESSING
  SUBMITTED
  SUCCEEDED
  FAILED_RETRYABLE
  FAILED_FINAL
  PAUSED
}

enum TreasuryAuditEventType {
  INITIAL_ALLOCATION_QUEUED
  INITIAL_ALLOCATION_BLOCKED_PAUSED
  INITIAL_ALLOCATION_BLOCKED_ALREADY_FUNDED
  INITIAL_ALLOCATION_REQUESTED
  INITIAL_ALLOCATION_SUBMITTED
  INITIAL_ALLOCATION_CONFIRMED
  INITIAL_ALLOCATION_FAILED
  INITIAL_ALLOCATION_RETRY_SCHEDULED

  INITIAL_GAS_FUNDING_QUEUED
  INITIAL_GAS_FUNDING_BLOCKED_PAUSED
  INITIAL_GAS_FUNDING_BLOCKED_ALREADY_FUNDED
  INITIAL_GAS_FUNDING_REQUESTED
  INITIAL_GAS_FUNDING_SUBMITTED
  INITIAL_GAS_FUNDING_CONFIRMED
  INITIAL_GAS_FUNDING_FAILED
  INITIAL_GAS_FUNDING_RETRY_SCHEDULED

  LOW_BALANCE_GAS_REFILL_QUEUED
  LOW_BALANCE_GAS_REFILL_BLOCKED_PAUSED
  LOW_BALANCE_GAS_REFILL_BLOCKED_ALREADY_FUNDED
  LOW_BALANCE_GAS_REFILL_REQUESTED
  LOW_BALANCE_GAS_REFILL_SUBMITTED
  LOW_BALANCE_GAS_REFILL_CONFIRMED
  LOW_BALANCE_GAS_REFILL_FAILED
  LOW_BALANCE_GAS_REFILL_RETRY_SCHEDULED

  GOVERNANCE_REBALANCE_TOPUP_QUEUED
  GOVERNANCE_REBALANCE_TOPUP_BLOCKED_PAUSED
  GOVERNANCE_REBALANCE_TOPUP_BLOCKED_ALREADY_FUNDED
  GOVERNANCE_REBALANCE_TOPUP_REQUESTED
  GOVERNANCE_REBALANCE_TOPUP_SUBMITTED
  GOVERNANCE_REBALANCE_TOPUP_CONFIRMED
  GOVERNANCE_REBALANCE_TOPUP_FAILED
  GOVERNANCE_REBALANCE_TOPUP_RETRY_SCHEDULED
}

enum UserRole {
  MEMBER
  DELEGATE
  ADMIN
  VIEWER
}

enum AccountCloseAttemptStatus {
  PREPARED
  AUTHORIZATION_SIGNED
  AUTHORIZATION_STORED
  EXECUTION_QUEUED
  EXECUTION_SUBMITTED
  EXECUTION_CONFIRMED
  FINALIZED
  EXPIRED
  FAILED
}

enum ProposalCategory {
  COFFEE_MEETUP
  HACK_DAY
  WORKSHOP
  OTHER
}

model AccountCloseAttempt {
  id                            String                     @id @default(auto()) @map("_id") @db.ObjectId
  attemptKey                    String                     @unique

  userId                        String                     @db.ObjectId
  issuer                        String
  walletAddress                 String

  chainId                       Int
  recipientAddress              String

  delegateContractAddress       String
  relayerAddress                String?
  closeDeadline                 DateTime?

  authorizationNonce            String?
  authorizationChainId          Int?
  authorizationContractAddress  String?
  authorizationV                Int?
  authorizationR                String?
  authorizationS                String?
  authorizationSignedAt         DateTime?
  authorizationStoredAt         DateTime?

  closeIntentRelayer            String?
  closeIntentNonce              String?
  closeIntentDeadline           DateTime?
  closeIntentSignature          String?

  executionTxHash               String?
  executionBlockNumber          Int?
  executionQueuedAt             DateTime?
  executionSubmittedAt          DateTime?
  executionConfirmedAt          DateTime?

  status                        AccountCloseAttemptStatus  @default(PREPARED)
  expiresAt                     DateTime
  finalizedAt                   DateTime?

  lastErrorCode                 String?
  lastErrorMessage              String?

  createdAt                     DateTime                   @default(now())
  updatedAt                     DateTime                   @updatedAt

  @@index([userId, status])
  @@index([status, updatedAt])
  @@index([issuer])
  @@index([expiresAt])
  @@index([executionTxHash])
  @@index([relayerAddress])
}

model User {
  id                      String                      @id @default(auto()) @map("_id") @db.ObjectId
  issuer                  String?                     @unique
  email                   String
  normalizedEmail         String                      @unique
  passwordHash            String?
  name                    String?
  role                    UserRole                    @default(MEMBER)
  createdAt               DateTime                    @default(now())
  updatedAt               DateTime                    @updatedAt

  invitedByUserId         String?                     @db.ObjectId
  invitedByUser           User?                       @relation("UserInvites", fields: [invitedByUserId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  invitedUsers            User[]                      @relation("UserInvites")

  createdInviteCodes      InviteCode[]                @relation("InviteCodeCreator")
  redeemedInviteCodes     InviteCode[]                @relation("RedeemedInviteCodes")

  walletAddress           String?
  walletChain             String?
  walletProvider          String?
  walletResolutionStatus  AccountSetupStatus          @default(PENDING)
  walletResolvedAt        DateTime?
  walletResolutionError   String?

  accountSetupStatus      AccountSetupStatus          @default(PENDING)
  accountSetupUpdatedAt   DateTime?

  initialAllocationStatus TreasuryDistributionStatus?
  initialAllocationAt     DateTime?
  initialAllocationTxHash String?

  accountSetupEvents      AccountSetupEvent[]
  treasuryDistributions   TreasuryDistribution[]
  treasuryAuditLogs       TreasuryAuditLog[]
  proposals               ProposalRecord[]
}

model InviteCode {
  id               String           @id @default(auto()) @map("_id") @db.ObjectId
  code             String           @unique
  status           InviteCodeStatus @default(AVAILABLE)
  expiresAt        DateTime?
  redeemedAt       DateTime?
  redeemedByUserId String?          @db.ObjectId
  redeemedByUser   User?            @relation("RedeemedInviteCodes", fields: [redeemedByUserId], references: [id])

  createdByUserId  String           @db.ObjectId
  createdByUser    User             @relation("InviteCodeCreator", fields: [createdByUserId], references: [id])

  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
}

model AccountSetupEvent {
  id         String                @id @default(auto()) @map("_id") @db.ObjectId
  userId     String                @db.ObjectId
  user       User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  type       AccountSetupEventType
  status     AccountSetupStatus
  message    String?
  metadata   Json?
  createdAt  DateTime              @default(now())

  @@index([userId])
  @@index([type])
  @@index([createdAt])
}

model TreasuryDistribution {
  id               String                     @id @default(auto()) @map("_id") @db.ObjectId
  userId           String                     @db.ObjectId
  user             User                       @relation(fields: [userId], references: [id], onDelete: Cascade)

  kind             TreasuryDistributionKind
  status           TreasuryDistributionStatus @default(PENDING)

  amountBaseUnits  String
  tokenAddress     String?
  chainId          Int
  walletAddress    String

  txHash           String?
  idempotencyKey   String                     @unique
  attemptCount     Int                        @default(0)

  lastErrorCode    String?
  lastErrorMessage String?

  submittedAt      DateTime?
  confirmedAt      DateTime?
  processedAt      DateTime?

  createdAt        DateTime                   @default(now())
  updatedAt        DateTime                   @updatedAt

  @@unique([userId, kind])
  @@index([status, updatedAt])
  @@index([txHash])
}

model TreasuryAuditLog {
  id               String                @id @default(auto()) @map("_id") @db.ObjectId
  userId           String?               @db.ObjectId
  user             User?                 @relation(fields: [userId], references: [id], onDelete: SetNull)

  type             TreasuryAuditEventType
  actor            String                @default("system")

  normalizedEmail  String?
  issuer           String?
  walletAddress    String?
  kind             TreasuryDistributionKind?
  amountBaseUnits  String?
  tokenAddress     String?
  chainId          Int?
  txHash           String?
  idempotencyKey   String?

  errorCode        String?
  errorMessage     String?
  metadata         Json?

  createdAt        DateTime              @default(now())

  @@index([userId])
  @@index([type])
  @@index([createdAt])
}

model ProposalRecord {
  id                    String            @id @default(auto()) @map("_id") @db.ObjectId
  proposalId            String            @unique
  title                 String
  excerpt               String
  description           String
  descriptionHash       String?
  category              ProposalCategory
  proposerAddress       String
  proposerLabel         String
  proposerUserId        String?           @db.ObjectId
  proposerUser          User?             @relation(fields: [proposerUserId], references: [id], onDelete: SetNull)
  governorAddress       String
  registryAddress       String?
  governorTxHash        String?

  proposalKind          String?           // "standard" | "cancel"
  canceledProposalId    String?
  canceledProposalTitle String?
  cancelHighlightUntil  DateTime?
  cancelHiddenAt        DateTime?

  targets               Json?
  values                Json?
  calldatas             Json?

  votingStartsAt        DateTime?
  votingEndsAt          DateTime?
  queuedAt              DateTime?
  executableAt          DateTime?
  executedAt            DateTime?
  canceledAt            DateTime?
  defeatedAt            DateTime?

  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt

  @@index([category, createdAt])
  @@index([createdAt])
  @@index([proposerUserId])
  @@index([proposalId, votingEndsAt])
  @@index([proposalId, executableAt])
  @@index([proposalKind, createdAt])
  @@index([canceledProposalId])
  @@index([cancelHighlightUntil])
  @@index([cancelHiddenAt])
}